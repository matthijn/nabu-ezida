[
  {
    "name": "set fields with block_id",
    "fixture": "callouts-two.md",
    "storePath": "codebook.md",
    "tool": "patch_callout",
    "args": {
      "path": "codebook.md",
      "block_id": "callout_a",
      "operations": [{ "op": "set", "fields": { "content": "new" } }]
    },
    "expected": { "status": "ok", "outputMatch": "Patched.*json-callout" },
    "expectedFile": "set-with-id.expected.md"
  },
  {
    "name": "error when block_id missing with multiple blocks",
    "fixture": "callouts-two.md",
