  {
    "name": "patch_content applies field diff",
    "fixture": "callout-three-lines.md",
    "storePath": "codebook.md",
    "tool": "patch_callout",
    "args": {
      "path": "codebook.md",
      "block_id": "callout_a",
      "operations": [
        {
          "op": "patch_content",
          "diff": "@@\nLine one.\n-Line two.\n+Line two updated.\nLine three."
        }
      ]
    },
    "expected": { "status": "ok", "outputMatch": "Patched.*json-callout" },
    "expectedFile": "field-diff.expected.md"
  },
  {
    "name": "patch_content with set in same batch",
    "fixture": "callout-original-content.md",
    "storePath": "codebook.md",
    "tool": "patch_callout",
    "args": {
      "path": "codebook.md",
      "block_id": "callout_a",
      "operations": [
        { "op": "set", "fields": { "color": "red" } },
        { "op": "patch_content", "diff": "@@\n-Original content.\n+Updated content." }
      ]
    },
    "expected": { "status": "ok", "outputMatch": "Patched.*json-callout" },
    "expectedFile": "field-diff-with-set.expected.md"
  },
