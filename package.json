{
  "name": "nabu-theatron",
  "private": true,
  "type": "module",
  "scripts": {
    "postinstall": "cp node_modules/jq-web/jq.js public/jq.js && cp node_modules/jq-web/jq.wasm public/jq.wasm",
    "build": "react-router build",
    "dev": "react-router dev --force",
    "start": "react-router-serve ./build/server/index.js",
    "typecheck": "react-router typegen && tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "lint": "eslint app/",
    "lint:fix": "eslint app/ --fix",
    "format": "prettier --write 'app/**/*.{ts,tsx,json,css,md}'",
    "format:check": "prettier --check 'app/**/*.{ts,tsx,json,css,md}'",
    "prepare": "husky"
  },
  "lint-staged": {
    "app/**/*.{ts,tsx}": [
      "prettier --write",
      "eslint --fix"
    ],
    "*.{json,css,md}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "@duckdb/duckdb-wasm": "^1.33.1-dev20.0",
    "@milkdown/kit": "^7.18.0",
    "@milkdown/react": "^7.18.0",
    "@milkdown/utils": "^7.18.0",
    "@prosemirror-adapter/react": "^0.5.1",
    "@radix-ui/colors": "^3.0.0",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-collapsible": "^1.1.12",
    "@radix-ui/react-context-menu": "^2.2.16",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-hover-card": "^1.1.15",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-progress": "^1.1.8",
    "@radix-ui/react-radio-group": "^1.3.8",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-slider": "^1.3.6",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-toggle-group": "^1.1.11",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@react-router/node": "7.10.1",
    "@react-router/serve": "7.10.1",
    "@subframe/core": "latest",
    "@tailwindcss/typography": "^0.5.19",
    "classnames": "^2.5.1",
    "clsx": "^2.1.1",
    "copy-to-clipboard": "^3.3.3",
    "fast-json-patch": "^3.1.1",
    "framer-motion": "^12.23.26",
    "immer": "^11.0.1",
    "isbot": "^5.1.31",
    "jq-web": "^0.6.2",
    "minimatch": "^10.1.1",
    "mri": "^1.2.0",
    "prosemirror-model": "^1.25.4",
    "prosemirror-state": "^1.4.4",
    "prosemirror-view": "^1.41.4",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "react-markdown": "^10.1.0",
    "react-router": "7.10.1",
    "remark-gfm": "^4.0.1",
    "remark-parse": "^11.0.0",
    "shell-quote": "^1.8.3",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.4.0",
    "unified": "^11.0.5",
    "zod": "^4.3.5"
  },
  "devDependencies": {
    "@chromatic-com/storybook": "^4.1.3",
    "@eslint/js": "^9.39.4",
    "@react-router/dev": "7.10.1",
    "@storybook/addon-a11y": "^10.1.10",
    "@storybook/addon-docs": "^10.1.10",
    "@storybook/addon-onboarding": "^10.1.10",
    "@storybook/react-vite": "^10.1.10",
    "@tailwindcss/vite": "^4.1.13",
    "@types/mdast": "^4.0.4",
    "@types/node": "^22",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@types/shell-quote": "^1.7.5",
    "@vitest/browser-playwright": "^4.0.16",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react-hooks": "^7.0.1",
    "fast-deep-equal": "^3.1.3",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "playwright": "^1.57.0",
    "prettier": "^3.8.1",
    "storybook": "^10.1.10",
    "tailwindcss": "^4.1.13",
    "typescript": "^5.9.2",
    "typescript-eslint": "^8.57.1",
    "vite": "^7.1.7",
    "vite-tsconfig-paths": "^5.1.4",
    "vitest": "^4.0.16"
  }
